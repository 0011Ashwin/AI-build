# Justice AI — Environment Variables
# Copy this file to .env and fill in the values before running

# ── Google AI / ADK ────────────────────────────────────────────────────────
# Required for Gemini model calls (ADK uses this automatically)
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# ── Google Cloud (optional — needed for Vertex AI Vector Search in production)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1

# ── App Config ─────────────────────────────────────────────────────────────
PORT=8080
